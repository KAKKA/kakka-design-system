{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "config/**", "package.json", "tsconfig*.json"],
      "outputs": ["dist/**"]
    },
    "storybook:build": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", ".storybook/**"],
      "outputs": ["storybook-static/**"]
    },
    "storybook": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "inputs": ["src/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs": ["src/**", "tsconfig*.json"]
    },
    "clean": {
      "cache": false
    }
  }
}
